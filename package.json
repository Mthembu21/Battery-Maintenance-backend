{
  "name": "epiroc-battery-maintenance-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "dev:watch": "node --watch src/server.js",
    "start": "node src/server.js",
    "clean-port": "netstat -ano | findstr :4000 | for /f \"tokens=5\" %a in ('more') do taskkill /F /PID %a 2>nul || echo No process found on port 4000"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "zod": "^3.23.8"
  }
}
